<%= form_with(model: @budget, local: true) do |form| %>
  <div>
    <%= form.label :project_id %>
    <%= form.collection_select :project_id, Project.all, :id, :name %>
  </div>

  <div>
    <%= form.label :amount %>
    <%= form.number_field :amount %>
  </div>

  <div>
    <%= form.label :status %>
    <%= form.text_field :status %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>