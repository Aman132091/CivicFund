<h1>New Budget Allocation for <%= @project.name %></h1>

<%= form_with model: [@project, @budget], local: true do |form| %>
  <% if @budget.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@budget.errors.count, "error") %> prohibited this budget from being saved:</h2>
      <ul>
        <% @budget.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :amount %><br>
    <%= form.number_field :amount %>
  </div>

  <div>
    <%= form.label :status %><br>
    <%= form.text_field :status %>
  </div>

  <div>
    <%= form.submit "Allocate Budget" %>
  </div>
<% end %>

<%= link_to "Back to Project", project_path(@project) %>